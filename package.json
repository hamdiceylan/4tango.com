{
  "name": "4tango",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "status": "bash scripts/status.sh",
    "status:full": "bash scripts/status.sh full",
    "status:health": "node scripts/check-health.mjs",
    "status:deploy": "bash scripts/status.sh deploy",
    "status:git": "bash scripts/status.sh git",
