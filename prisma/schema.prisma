generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Organizer - The paying customer who creates events
model Organizer {
  id                    String    @id @default(cuid())
  name                  String
  email                 String    @unique
  logoUrl               String?
  stripeAccountId       String?
  defaultCurrency       String    @default("EUR")
  onboardingCompletedAt DateTime? // When organizer completed onboarding wizard
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  users          OrganizerUser[]
  events         Event[]
  preferences    OrganizerPreferences?
  emailTemplates EmailTemplate[]
  invitations    TeamInvitation[]
  dancerNotes    DancerNote[]
  dancerTags     DancerTag[]
  activityLogs   ActivityLog[]
}

// Organizer role enum for team management
enum OrganizerRole {
  OWNER
  ADMIN
  SITE_MANAGER
  FINANCE_MANAGER
  REGISTRATION_MANAGER
  VIEWER
}

// Team invitation status
enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

// Organizer Users - For multi-admin support with roles
model OrganizerUser {
  id            String        @id @default(cuid())
  organizerId   String
  email         String        @unique
  fullName      String
  role          OrganizerRole @default(ADMIN)
  cognitoUserId String?       @unique // AWS Cognito user ID for password auth
  passwordHash  String?       // For email/password auth (hashed)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  organizer       Organizer        @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  invitationsSent TeamInvitation[]
  dancerNotes     DancerNote[]
}

// Team invitation for adding new team members
model TeamInvitation {
  id          String           @id @default(cuid())
  organizerId String
  email       String
  role        OrganizerRole
  token       String           @unique
  invitedById String
  status      InvitationStatus @default(PENDING)
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime         @default(now())

  organizer Organizer     @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  invitedBy OrganizerUser @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([organizerId, email])
}

// Magic Link tokens for authentication
model MagicLinkToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

// Session for authenticated users
model Session {
  id           String   @id @default(cuid())
  userId       String
  userType     String   // "organizer" or "dancer"
  token        String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

// Event - Tango events created by organizers
model Event {
  id                   String      @id @default(cuid())
  organizerId          String
  title                String
  slug                 String      @unique
  shortDescription     String?
  description          String?
  coverImageUrl        String?
  city                 String
  country              String
  venueName            String?
  address              String?
  startAt              DateTime
  endAt                DateTime
  currency             String      @default("EUR")
  priceAmount          Int         @default(0) // In cents
  capacityLimit        Int?
  registrationOpensAt  DateTime?
  registrationClosesAt DateTime?
  status               EventStatus @default(DRAFT)
  djs                  String[]    // Array of DJ names
  // Theme settings for page builder
  primaryColor         String?     @default("#f43f5e") // rose-500
  logoUrl              String?
  bannerUrl            String?
  // i18n settings
  defaultLanguage      String      @default("en")
  availableLanguages   String[]    @default(["en"])
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  organizer      Organizer          @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  registrations  Registration[]
  pageSections   EventPageSection[]
  formFields     EventFormField[]
  packages       EventPackage[]
  emailTemplates EmailTemplate[]
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CLOSED
  CANCELLED
}

// Dancer - Central dancer database built from registrations
model Dancer {
  id                String     @id @default(cuid())
  email             String     @unique
  fullName          String
  role              DancerRole @default(FOLLOWER)
  city              String?
  country           String?
  profilePictureUrl String?
  bio               String?    @db.Text
  phoneNumber       String?
  websiteUrl        String?
  socialLinks       Json?      // { instagram, facebook }
  preferences       Json?      // { emailNotifications }
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  registrations Registration[]
  auth          DancerAuth?
  notes         DancerNote[]
  tags          DancerTagAssignment[]
}

// DancerAuth - Authentication data for dancers (social login)
model DancerAuth {
  id                 String    @id @default(cuid())
  dancerId           String    @unique
  cognitoUserId      String    @unique // AWS Cognito user ID from social provider
  provider           String?   // "google", "apple", "facebook"
  providerPictureUrl String?   // OAuth profile picture URL
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  dancer Dancer @relation(fields: [dancerId], references: [id], onDelete: Cascade)
}

enum DancerRole {
  LEADER
  FOLLOWER
  SWITCH
}

// Registration - Event registrations
model Registration {
  id                 String             @id @default(cuid())
  eventId            String
  dancerId           String
  // Snapshots at time of registration
  fullNameSnapshot   String
  emailSnapshot      String
  roleSnapshot       DancerRole
  citySnapshot       String?
  countrySnapshot    String?
  experience         String?
  partnerEmail       String?
  dietaryRestrictions String?
  notes              String?
  internalNote       String?
  // Package selection
  packageId          String?
  // Status
  registrationStatus RegistrationStatus @default(REGISTERED)
  paymentStatus      PaymentStatus      @default(UNPAID)
  paymentProvider    String?            // "stripe"
  paymentReference   String?            // Stripe payment intent ID
  paymentAmount      Int?               // Amount in cents
  // Secure access token for dancer to view their registration
  accessToken        String             @unique @default(cuid())
  // Email tracking
  emailSentAt        DateTime?
  emailDeliveredAt   DateTime?
  emailOpenedAt      DateTime?
  emailClickedAt     DateTime?
  emailBouncedAt     DateTime?
  // Timestamps
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  event             Event                    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  dancer            Dancer                   @relation(fields: [dancerId], references: [id], onDelete: Cascade)
  emailEvents       EmailEvent[]
  customFieldValues RegistrationFieldValue[]

  @@unique([eventId, dancerId])
}

enum RegistrationStatus {
  REGISTERED      // Initial registration
  PENDING_REVIEW  // Awaiting organizer review
  APPROVED        // Accepted, awaiting payment
  CONFIRMED       // Fully confirmed
  WAITLIST        // On waiting list
  REJECTED        // Declined by organizer
  CANCELLED       // Registration cancelled
  CHECKED_IN      // Checked in at event
}

enum PaymentStatus {
  UNPAID          // No payment yet
  PENDING         // Payment in progress
  PAID            // Fully paid
  PARTIALLY_PAID  // Partial payment received
  PAYMENT_FAILED  // Payment attempt failed
  REFUNDED        // Fully refunded
  REFUND_PENDING  // Refund in progress
}

// Email Events - Track email delivery status from SES
model EmailEvent {
  id               String   @id @default(cuid())
  registrationId   String
  eventType        String   // sent, delivered, opened, clicked, bounced, complained
  providerMessageId String?
  payloadJson      String?  @db.Text
  occurredAt       DateTime
  createdAt        DateTime @default(now())

  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
}

// ==========================================
// PAGE BUILDER MODELS
// ==========================================

// Event page sections for custom page builder
model EventPageSection {
  id        String      @id @default(cuid())
  eventId   String
  type      SectionType
  order     Int
  title     String?
  content   Json        // Section-specific data (varies by type)
  isVisible Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, order])
}

enum SectionType {
  HERO
  ABOUT
  SCHEDULE
  ACCOMMODATION
  DJ_TEAM
  PHOTOGRAPHERS
  PRICING
  GALLERY
  CONTACT
  CUSTOM_TEXT
  CUSTOM_HTML
}

// ==========================================
// FORM BUILDER MODELS
// ==========================================

// Custom form fields for registration form builder
model EventFormField {
  id            String    @id @default(cuid())
  eventId       String
  fieldType     FieldType
  name          String    // Internal field name (e.g., "check_in_date")
  label         String    // Display label (e.g., "Check-in Date")
  placeholder   String?
  helpText      String?
  isRequired    Boolean   @default(false)
  order         Int
  options       Json?     // For SELECT/RADIO: [{value: "option1", label: "Option 1"}]
  validation    Json?     // {min, max, pattern, minLength, maxLength, etc.}
  conditionalOn Json?     // {fieldName: "role", value: "leader"} - show only when condition met
  // i18n fields for multi-language support
  labels        Json?     // { en: "Full Name", es: "Nombre Completo" }
  placeholders  Json?     // { en: "Enter your name", es: "Ingrese su nombre" }
  helpTexts     Json?     // { en: "Help text", es: "Texto de ayuda" }
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, order])
}

enum FieldType {
  TEXT
  EMAIL
  TEL
  NUMBER
  DATE
  DATETIME
  SELECT
  RADIO
  CHECKBOX
  TEXTAREA
  URL
  FILE
}

// Registration custom field values - stores answers to custom form fields
model RegistrationFieldValue {
  id             String @id @default(cuid())
  registrationId String
  fieldId        String // References EventFormField.id
  value          String @db.Text

  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@unique([registrationId, fieldId])
  @@index([registrationId])
}

// ==========================================
// PRICING PACKAGES
// ==========================================

// Event pricing packages for accommodation/package selection
model EventPackage {
  id          String   @id @default(cuid())
  eventId     String
  name        String
  description String?  @db.Text
  price       Int      // In cents
  currency    String   @default("EUR")
  capacity    Int?     // Max people who can select this package
  order       Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, order])
}

// ==========================================
// ORGANIZER PREFERENCES
// ==========================================

// Organizer preferences for customizable table views and settings
model OrganizerPreferences {
  id                  String   @id @default(cuid())
  organizerId         String   @unique
  registrationColumns Json?    // Column visibility and order for registration table
  defaultEventId      String?  // Last selected event for single-event dashboard view
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organizer Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)
}

// ==========================================
// EMAIL TEMPLATES
// ==========================================

// Custom email templates for organizers
model EmailTemplate {
  id          String   @id @default(cuid())
  organizerId String
  eventId     String?  // null = organization-wide template
  name        String   // e.g., "Confirmation", "Reminder", "Payment Request"
  subject     String
  htmlContent String   @db.Text
  variables   Json     // Available variables: [{name: "dancerName", description: "Full name of dancer"}]
  language    String   @default("en")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizer Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  event     Event?    @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@unique([organizerId, name, language])
  @@index([organizerId])
  @@index([eventId])
}

// ==========================================
// DANCER MANAGEMENT (for Organizers)
// ==========================================

// Internal notes about dancers (visible only to organizer team)
model DancerNote {
  id          String   @id @default(cuid())
  dancerId    String
  organizerId String
  content     String   @db.Text
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  dancer    Dancer        @relation(fields: [dancerId], references: [id], onDelete: Cascade)
  organizer Organizer     @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  createdBy OrganizerUser @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([dancerId, organizerId])
}

// Tags for categorizing dancers (per organizer)
model DancerTag {
  id          String   @id @default(cuid())
  organizerId String
  name        String
  color       String   @default("#6B7280")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizer   Organizer             @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  assignments DancerTagAssignment[]

  @@unique([organizerId, name])
}

// Assignment of tags to dancers
model DancerTagAssignment {
  id        String   @id @default(cuid())
  dancerId  String
  tagId     String
  createdAt DateTime @default(now())

  dancer Dancer    @relation(fields: [dancerId], references: [id], onDelete: Cascade)
  tag    DancerTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([dancerId, tagId])
}

// ==========================================
// ACTIVITY LOG / AUDIT TRAIL
// ==========================================

enum ActivityCategory {
  REGISTRATION
  PAYMENT
  COMMUNICATION
  TEAM
  EVENT
  SETTINGS
}

model ActivityLog {
  id          String           @id @default(cuid())
  organizerId String
  actorId     String           // OrganizerUser who performed the action
  actorEmail  String           // Snapshot (preserved if user deleted)
  actorName   String           // Snapshot (preserved if user deleted)

  action      String           // e.g., "registration.approve", "team.invite"
  category    ActivityCategory

  entityType  String           // "registration", "event", "team_member"
  entityId    String
  entityLabel String?          // Human-readable (e.g., dancer name)

  changes     Json?            // { field: { old: value, new: value } }
  metadata    Json?            // Additional context

  eventId        String?       // For fast event filtering
  registrationId String?       // For fast registration filtering

  ipAddress   String?
  userAgent   String?

  createdAt   DateTime @default(now())

  organizer   Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)

  @@index([organizerId, createdAt])
  @@index([organizerId, action])
  @@index([organizerId, entityType, entityId])
  @@index([organizerId, actorId])
  @@index([eventId])
  @@index([registrationId])
}
